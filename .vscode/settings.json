{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      // 使用 Ruff 来自动修复和组织导入
      "source.fixAll.ruff": "always",
      "source.organizeImports.ruff": "always"
    }
  },
  // 禁用传统的 isort 插件，防止冲突
  "isort.checkOnSave": false,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true
  }
}
