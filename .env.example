# DeepSeek API configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Service configuration
APP_HOST=0.0.0.0
APP_PORT=10461
APP_DEBUG=false

# Redis chat history configuration
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=chat_history
CHAT_HISTORY_TTL_SECONDS=86400

# WeWork callback configuration
NOTIFY_CALLBACK_URL=https://your-domain.com/api/wework/callback

# Thesis model configuration
THESIS_OUTLINE_MODEL=deepseek-chat
THESIS_FULLTEXT_MODEL=deepseek-reasoner

# 12AI Gemini Configuration
TWELVEAI_API_KEY=your_twelveai_api_key_here
TWELVEAI_IMAGE_MODEL=gemini-3-pro-image-preview

# OpenRouter Configuration (Backup)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Optional: reference search for thesis bibliography
SERPAPI_KEY=
